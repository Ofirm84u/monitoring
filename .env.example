# Auth — password for the dashboard
MONITOR_PASSWORD=changeme

# Secret for the monitor script to call the alert API
MONITOR_SECRET=generate-with-openssl-rand-hex-16

# Email alerts
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your-app-password
MONITOR_ALERT_EMAIL=your@email.com

# Status file path (written by server-monitor.sh cron script)
STATUS_FILE=/home/ofir/monitoring/status.json
LOG_FILE=/home/ofir/monitoring/monitor.log

# Article summarizer (Claude API)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ARTICLES_FILE=/home/ofir/monitor/articles.json

# Telegram bot (Phase 2) — runs as PM2 process scripts/bot.py
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=
# Shared secret between the bot and the MonitoringApp HTTP API
BOT_API_TOKEN=generate-with-openssl-rand-hex-32
MONITOR_BOT_TOKEN=<same-as-BOT_API_TOKEN>
MONITOR_API_URL=http://localhost:3040

# Per-project code-context paths (optional, for richer gap analysis).
# Format: CODE_CONTEXT_<PROJECT_ID_UPPER>=/abs/path/to/main-file
# Project IDs are from src/lib/projects.ts (dashes become underscores).
# Example:
# CODE_CONTEXT_SEOAPP=/home/ofir/seoapp/v15/v15.py
# CODE_CONTEXT_QA_AUTOMATION=/home/ofir/qa-automation/src/index.ts
